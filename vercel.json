{
  "crons": [
    {
      "path": "/api/cron/reminder",
      "schedule": "0 8 * * *"
    }
  ],
  "rewrites": [
    { "source": "/.env", "destination": "/404" },
    { "source": "/.env.local", "destination": "/404" },
    { "source": "/.env.production", "destination": "/404" },
    { "source": "/.git/:path*", "destination": "/404" }
  ],
  "headers": [
    {
      "source": "/.env(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}
